<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- PRD-08: Structured JSON Logging Configuration -->
    <!-- Local profile: Pretty-printed JSON to console -->
    <!-- Production profile: Plain JSON to file for CloudWatch Agent ingestion -->

    <!-- Import Spring Boot defaults -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- ──────────────────────────────────────────────────────────────────── -->
    <!-- APPENDERS -->
    <!-- ──────────────────────────────────────────────────────────────────── -->

    <!-- Console Appender - Pretty JSON for local development -->
    <springProfile name="local">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <!-- Include all MDC fields in JSON output -->
                <includeMdcKeyName>true</includeMdcKeyName>
                <fieldNames>
                    <timestamp>@timestamp</timestamp>
                    <message>message</message>
                    <level>level</level>
                    <levelValue>level_value</levelValue>
                    <loggerName>logger_name</loggerName>
                    <thread>thread_name</thread>
                    <context>context_name</context>
                    <version>version</version>
                </fieldNames>
                <!-- Add custom fields -->
                <customFields>{"environment":"local"}</customFields>
            </encoder>
        </appender>
    </springProfile>

    <!-- File Appender - Plain JSON for production (CloudWatch Agent will read from here) -->
    <springProfile name="prod">
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>/var/log/reviewflow/application.log</file>
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdcKeyName>true</includeMdcKeyName>
                <fieldNames>
                    <timestamp>@timestamp</timestamp>
                    <message>message</message>
                    <level>level</level>
                    <levelValue>level_value</levelValue>
                    <loggerName>logger_name</loggerName>
                    <thread>thread_name</thread>
                    <context>context_name</context>
                    <version>version</version>
                </fieldNames>
                <customFields>{"environment":"prod"}</customFields>
            </encoder>
            <!-- Rolling policy: rotate daily, keep 30 days -->
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>/var/log/reviewflow/application.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                <maxHistory>30</maxHistory>
                <maxFileSize>100MB</maxFileSize>
            </rollingPolicy>
        </appender>
    </springProfile>

    <!-- Async Appender - improves performance by buffering logs -->
    <appender name="ASYNC_CONSOLE" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="CONSOLE"/>
        <queueSize>2048</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <maxFlushTime>10000</maxFlushTime>
        <neverBlock>false</neverBlock>
        <includeCallerData>false</includeCallerData>
    </appender>

    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="FILE"/>
        <queueSize>2048</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <maxFlushTime>10000</maxFlushTime>
        <neverBlock>false</neverBlock>
        <includeCallerData>false</includeCallerData>
    </appender>

    <!-- ──────────────────────────────────────────────────────────────────── -->
    <!-- ROOT LOGGER -->
    <!-- ──────────────────────────────────────────────────────────────────── -->

    <springProfile name="local">
        <root level="${LOG_LEVEL_ROOT:INFO}">
            <appender-ref ref="ASYNC_CONSOLE"/>
        </root>
    </springProfile>

    <springProfile name="prod">
        <root level="${LOG_LEVEL_ROOT:INFO}">
            <appender-ref ref="ASYNC_FILE"/>
        </root>
    </springProfile>

    <!-- ──────────────────────────────────────────────────────────────────── -->
    <!-- LOGGER LEVELS -->
    <!-- ──────────────────────────────────────────────────────────────────── -->

    <!-- ReviewFlow application logging -->
    <logger name="com.reviewflow" level="${LOG_LEVEL_REVIEWFLOW:INFO}"/>

    <!-- Hibernate SQL logging -->
    <logger name="org.hibernate.SQL" level="${LOG_LEVEL_SQL:WARN}"/>
    <logger name="org.hibernate.orm.jdbc.bind" level="WARN"/>

    <!-- Spring Boot logging -->
    <logger name="org.springframework.boot" level="INFO"/>
    <logger name="org.springframework.security" level="INFO"/>

    <!-- Third-party -->
    <logger name="org.apache.commons" level="WARN"/>
    <logger name="org.apache.tika" level="WARN"/>

</configuration>
