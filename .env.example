# .env.example — copy to .env and fill in values — NEVER commit .env

# ── Database ──────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=set_database_url_here
SPRING_DATASOURCE_USERNAME=set_database_username_here
SPRING_DATASOURCE_PASSWORD=your_secure_password_here

# ── Server ────────────────────────────────────────────────────────
SERVER_PORT=8081
SPRING_PROFILES_ACTIVE=local

# ── JWT ───────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=your_256_bit_base64_encoded_secret_here
JWT_ACCESS_EXPIRATION_MS=set_access_expiration_ms_here
JWT_REFRESH_EXPIRATION_MS=set_refresh_expiration_ms_here
JWT_COOKIE_NAME=set_cookie_name_here
JWT_REFRESH_COOKIE_NAME=set_refresh_cookie_name_here

# ── CORS ──────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=set_allowed_origins_here_comma_separated

# ── Cookie ────────────────────────────────────────────────────────
COOKIE_SECURE=set_to_true_in_production
COOKIE_SAME_SITE=set_to_Lax_or_Strict_here

# ── File Upload ───────────────────────────────────────────────────
MAX_FILE_SIZE=set_max_file_size_here
MAX_REQUEST_SIZE=set_max_request_size_here
MAX_UPLOAD_SIZE=set_max_upload_size_here
MAX_ARCHIVE_ENTRIES=set_max_archive_entries_here
MAX_ARCHIVE_UNCOMPRESSED_SIZE=set_max_uncompressed_size_here
MIME_DETECTION_TIMEOUT_MS=set_mime_detection_timeout_ms_here

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_LOGIN_MAX_ATTEMPTS=set_max_attempts_here
RATE_LIMIT_LOGIN_WINDOW_SECONDS=set_window_seconds_here
RATE_LIMIT_TOKEN_MAX_ATTEMPTS=set_max_attempts_here
RATE_LIMIT_TOKEN_WINDOW_SECONDS=set_window_seconds_here
RATE_LIMIT_UPLOAD_BLOCK_MAX_ATTEMPTS=set_max_attempts_here
RATE_LIMIT_UPLOAD_BLOCK_WINDOW_SECONDS=set_window_seconds_here
RATE_LIMIT_CLEANUP_INTERVAL_MS=set_cleanup_interval_ms_here

# ── ClamAV ────────────────────────────────────────────────────────
CLAMAV_HOST=your_clamav_host_here
CLAMAV_PORT=your_clamav_port_here
CLAMAV_TIMEOUT_MS=your_clamav_timeout_ms_here
CLAMAV_ENABLED=set_to_true_to_enable_clamav

# ── Token Fingerprinting ──────────────────────────────────────────
TOKEN_FINGERPRINTING_ENABLED=false

# ── Hashids ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# WARNING: Never change this after first deployment
HASHIDS_SALT=your_random_salt_here
HASHIDS_MIN_LENGTH=8

# ── Storage ───────────────────────────────────────────────────────
STORAGE_BASE_PATH=./storage

# ── Swagger/OpenAPI ───────────────────────────────────────────────
SWAGGER_PROD_URL=https://api.yourdomain.com

# ── Logging ───────────────────────────────────────────────────────
JPA_SHOW_SQL=set_to_true_to_show_sql
JPA_FORMAT_SQL=set_to_true_to_format_sql

# ── Email ─────────────────────────────────────────────────────────
# Local dev (Mailhog)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false

# Production (AWS SES SMTP)
# MAIL_HOST=email-smtp.ca-central-1.amazonaws.com
# MAIL_PORT=587
# MAIL_USERNAME=your_ses_smtp_username
# MAIL_PASSWORD=your_ses_smtp_password
# MAIL_SMTP_AUTH=true
# MAIL_SMTP_STARTTLS=true

EMAIL_FROM=noreply@reviewflow.com
EMAIL_THREAD_POOL_CORE=2
EMAIL_THREAD_POOL_MAX=10
EMAIL_THREAD_POOL_QUEUE=100
