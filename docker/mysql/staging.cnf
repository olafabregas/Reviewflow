# ─────────────────────────────────────────────────────────────
# ReviewFlow — MySQL Staging Config
# Tuned for t3.micro (2GB RAM total)
# MySQL budget: ~300MB
# ─────────────────────────────────────────────────────────────

[mysqld]

# ── Character set ──────────────────────────────────────────────
character-set-server  = utf8mb4
collation-server      = utf8mb4_unicode_ci

# ── InnoDB memory (keep small — t3.micro is tight) ────────────
# Buffer pool: primary InnoDB cache for data + indexes
# On t3.micro with Spring Boot taking 512MB, keep this low
innodb_buffer_pool_size         = 128M
innodb_buffer_pool_instances    = 1
innodb_log_file_size            = 48M
innodb_flush_log_at_trx_commit  = 2   # slight perf gain — safe for staging
innodb_flush_method             = O_DIRECT

# ── Connection limits ──────────────────────────────────────────
max_connections        = 50    # Spring Boot HikariCP default pool = 10
max_connect_errors     = 10000
wait_timeout           = 600
interactive_timeout    = 600

# ── Query cache (disabled in MySQL 8 — explicit) ──────────────
# MySQL 8 removed query cache — no config needed

# ── Slow query log (useful for staging debugging) ─────────────
slow_query_log         = 1
slow_query_log_file    = /var/lib/mysql/slow-queries.log
long_query_time        = 2     # log queries taking > 2 seconds

# ── Binary logging (not needed for staging) ───────────────────
skip-log-bin

# ── Performance schema (lightweight) ──────────────────────────
performance_schema = OFF   # saves ~300MB on t3.micro

[client]
default-character-set = utf8mb4
