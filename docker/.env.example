# EC2 deployment environment template
# Copy to /opt/reviewflow/.env and fill in all values.
# NEVER commit the filled .env file.

# ── Database ──────────────────────────────────────────────────────
DB_ROOT_PASSWORD=
DB_PASSWORD=
DB_USERNAME=reviewflow
DB_NAME=reviewflow

# ── Redis ─────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ── Auth / crypto (generate with: openssl rand -base64 32) ────────
JWT_SECRET=
HASHIDS_SALT=

# ── AWS / S3 ──────────────────────────────────────────────────────
AWS_REGION=ca-central-1
S3_BUCKET=reviewflow-storage
S3_REGION=ca-central-1
S3_PUBLIC_BASE_URL=

# ── CORS / cookies (production SecurityStartupValidator) ────────
CORS_ALLOWED_ORIGINS=https://staging.reviewflowlms.com
APP_COOKIE_SECURE=true
SECURITY_TOKEN_FINGERPRINTING_ENABLED=true

# ── Mail ──────────────────────────────────────────────────────────
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
EMAIL_FROM=noreply@reviewflowlms.com

# ── Optional ──────────────────────────────────────────────────────
REDIS_MESSAGING_PUBSUB_ENABLED=false
CLAMAV_ENABLED=false
